              <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
            </div>
            <div class="hl-notif-body">
              <div class="hl-notif-row"><span class="hl-notif-title">Order created</span><span class="hl-notif-time">1 min ago</span></div>
              <div class="hl-notif-desc">Your order is being processed instantly.</div>
            </div>
          </div>
          <div class="hl-notif">
            <div class="hl-notif-av green">
              <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M15 7h3a5 5 0 0 1 5 5 5 5 0 0 1-5 5h-3m-6 0H6a5 5 0 0 1-5-5 5 5 0 0 1 5-5h3"/><line x1="8" y1="12" x2="16" y2="12"/></svg>
            </div>
            <div class="hl-notif-body">
              <div class="hl-notif-row"><span class="hl-notif-title">Key delivered</span><span class="hl-notif-time">1 min ago</span></div>
              <div class="hl-notif-desc">Your key has been delivered instantly.</div>
            </div>
          </div>
          <div class="hl-notif faded">
            <div class="hl-notif-av">
              <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
            </div>
            <div class="hl-notif-body">
              <div class="hl-notif-row"><span class="hl-notif-title">User registered</span><span class="hl-notif-time">2 min ago</span></div>
              <div class="hl-notif-desc">Instant access granted.</div>
            </div>
          </div>
        </div>
        <div class="hl-label">
          <h3>Notifications</h3>
          <p>Get notified when something happens.</p>
        </div>
      </div>

      <!-- ════════════════════════
           SUPPORT CARD
           ════════════════════════ -->
      <div class="hl-card hl-support-card">
        <div class="hl-sup-num">24/7</div>
        <div class="hl-sup-word">SUPPORT</div>
        <div class="hl-sup-btns">
          <a href="/support" class="hl-btn hl-btn-primary">
            <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
            Support Page
          </a>
          <a href="https://discord.gg/apexsolutions" target="_blank" rel="noopener" class="hl-btn hl-btn-secondary">
            <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
            Get Support
          </a>
        </div>
      </div>

    </div>
  </div>
</section>

<script>
(function () {

  /* ═══════════════════════════════════════════════
     GLOBE — continent-accurate dots + drag-to-spin
  ═══════════════════════════════════════════════ */
  const canvas = document.getElementById('hlGlobe');
  if (!canvas) return;
  const ctx = canvas.getContext('2d');
  const W = 200, H = 200;
  canvas.width = W; canvas.height = H;
  const cx = W/2, cy = H/2, R = 76;

  /* Land mask — approximate continental regions */
  function isLand(lat, lon) {
    while (lon > 180)  lon -= 360;
    while (lon < -180) lon += 360;
    // ── Major ocean exclusions ──
    if (lat>51&&lat<66&&lon>-96&&lon<-77) return false;   // Hudson Bay
    if (lat>17&&lat<31&&lon>-97&&lon<-82) return false;   // Gulf of Mexico
    if (lat>9&&lat<23&&lon>-88&&lon<-60)  return false;   // Caribbean Sea
    if (lat>30&&lat<47&&lon>5&&lon<17)    return false;   // W Mediterranean
    if (lat>30&&lat<43&&lon>17&&lon<30)   return false;   // E Mediterranean
    if (lat>12&&lat<30&&lon>33&&lon<44)   return false;   // Red Sea
    if (lat>23&&lat<31&&lon>47&&lon<57)   return false;   // Persian Gulf
    if (lat>36&&lat<48&&lon>49&&lon<55)   return false;   // Caspian Sea
    if (lat>40&&lat<47&&lon>28&&lon<42)   return false;   // Black Sea
    if (lat>-5&&lat<16&&lon>102&&lon<122) return false;   // South China Sea
    // ── Land ──
    if (lat>59&&lat<84&&lon>-58&&lon<-17) return true;    // Greenland
    if (lat>63&&lat<67&&lon>-25&&lon<-13) return true;    // Iceland
    if (lat>49&&lat<59&&lon>-11&&lon<2)   return true;    // British Isles
    if (lat>54&&lat<72&&lon>-169&&lon<-130) return true;  // Alaska
    if (lat>49&&lat<73&&lon>-140&&lon<-53) return true;   // Canada
    if (lat>24&&lat<50&&lon>-125&&lon<-66) return true;   // USA
    if (lat>13&&lat<32&&lon>-118&&lon<-86) return true;   // Mexico
    if (lat>7&&lat<18&&lon>-92&&lon<-75)  return true;    // Central America
    if (lat>19&&lat<23&&lon>-85&&lon<-73) return true;    // Cuba
    if (lat>-56&&lat<13&&lon>-82&&lon<-34) return true;   // South America
    if (lat>55&&lat<72&&lon>4&&lon<32)    return true;    // Scandinavia
    if (lat>46&&lat<56&&lon>-5&&lon<24)   return true;    // C Europe
    if (lat>36&&lat<48&&lon>-9&&lon<30)   return true;    // S Europe
    if (lat>36&&lat<42&&lon>26&&lon<45)   return true;    // Turkey
    if (lat>60&&lat<72&&lon>24&&lon<38)   return true;    // Finland/Baltics
    if (lat>18&&lat<38&&lon>-6&&lon<37)   return true;    // N Africa
    if (lat>-5&&lat<18&&lon>-18&&lon<52)  return true;    // W/C Africa
    if (lat>-35&&lat<-4&&lon>11&&lon<52)  return true;    // S/E Africa
    if (lat>-26&&lat<-12&&lon>43&&lon<51) return true;    // Madagascar
    if (lat>12&&lat<38&&lon>33&&lon<62)   return true;    // Arabia / Middle East
    if (lat>50&&lat<78&&lon>28&&lon<180)  return true;    // Russia
    if (lat>55&&lat<68&&lon>-180&&lon<-163) return true;  // Chukotka
    if (lat>36&&lat<50&&lon>50&&lon<90)   return true;    // Central Asia
    if (lat>6&&lat<30&&lon>66&&lon<92)    return true;    // India
    if (lat>0&&lat<30&&lon>92&&lon<110)   return true;    // Indochina
    if (lat>18&&lat<55&&lon>72&&lon<145)  return true;    // China / E Asia
    if (lat>-10&&lat<7&&lon>94&&lon<145)  return true;    // SE Asia islands
    if (lat>4&&lat<20&&lon>117&&lon<128)  return true;    // Philippines
    if (lat>30&&lat<46&&lon>125&&lon<148) return true;    // Japan / Korea
    if (lat>-44&&lat<-10&&lon>113&&lon<154) return true;  // Australia
    if (lat>-47&&lat<-34&&lon>166&&lon<178) return true;  // New Zealand
    if (lat<-67) return true;                             // Antarctica
    return false;
  }

  /* Generate dots — land + sparse ocean for sphere shape */
  const PHI = Math.PI * (3 - Math.sqrt(5));
  const LAND = [], SEA = [];
  const N = 8000;

  for (let i = 0; i < N; i++) {
    const y = 1 - (i / (N-1)) * 2;
    const r = Math.sqrt(1 - y*y);
    const t = PHI * i;
    const bx = Math.cos(t)*r, bz = Math.sin(t)*r;
    const lat = Math.asin(y) * 180/Math.PI;
    const lon = Math.atan2(bz, bx) * 180/Math.PI;
    if (isLand(lat, lon)) {
      LAND.push({ bx, by: y, bz });
    } else if (i % 6 === 0) {
      SEA.push({ bx, by: y, bz });    // sparse ocean
    }
  }

  /* Rotation state */
  let aY = 0, aX = 0.15, tY = 0, tX = 0.15;
  let drag = false, lx = 0, ly = 0, vx = 0, vy = 0, auto = true;
  const wrap = document.getElementById('hlGlobeWrap');

  wrap.addEventListener('mousedown', e => {
    drag = true; auto = false; lx = e.clientX; ly = e.clientY; vx = vy = 0;
  });
  wrap.addEventListener('touchstart', e => {
    drag = true; auto = false;
    lx = e.touches[0].clientX; ly = e.touches[0].clientY; vx = vy = 0;
  }, { passive: true });

  function onMove(e) {
    if (!drag) return;
    const px = e.touches ? e.touches[0].clientX : e.clientX;
    const py = e.touches ? e.touches[0].clientY : e.clientY;
    vy = (py - ly) * 0.004; vx = (px - lx) * 0.004;
    tX += vy; tY += vx; lx = px; ly = py;
  }
  window.addEventListener('mousemove', onMove);
  window.addEventListener('touchmove', onMove, { passive: false });

  function onUp() {
    drag = false;
    setTimeout(() => { auto = true; }, 2000);
  }
  window.addEventListener('mouseup', onUp);
  window.addEventListener('touchend', onUp);

  function project(pts, cosX, sinX, cosY, sinY) {
    return pts.map(p => {
      const x1 = p.bx*cosY - p.bz*sinY;
      const z1 = p.bx*sinY + p.bz*cosY;
      const y2 = p.by*cosX - z1*sinX;
      const z2 = p.by*sinX + z1*cosX;
      return { sx: cx + x1*R, sy: cy + y2*R, z: z2 };
    }).sort((a,b) => a.z - b.z);
  }

  function draw() {
    ctx.clearRect(0, 0, W, H);
    if (!drag) {
      if (auto) tY += 0.004;
      vx *= 0.93; vy *= 0.93;
      tX += vy; tY += vx;
    }
    aX += (tX - aX) * 0.1;
    aY += (tY - aY) * 0.1;

    const cosX = Math.cos(aX), sinX = Math.sin(aX);
    const cosY = Math.cos(aY), sinY = Math.sin(aY);

    /* Ocean dots — very faint */
    project(SEA, cosX, sinX, cosY, sinY).forEach(p => {
      const d = (p.z + 1) / 2;
      if (d < 0.1) return;
      ctx.beginPath();
      ctx.arc(p.sx, p.sy, d * 0.55 + 0.1, 0, Math.PI*2);
      ctx.fillStyle = 'rgba(120,140,255,' + (d * 0.06).toFixed(2) + ')';
      ctx.fill();
    });

    /* Land dots — bright white */
    project(LAND, cosX, sinX, cosY, sinY).forEach(p => {
      const d = (p.z + 1) / 2;
      if (d < 0.08) return;
      ctx.beginPath();
      ctx.arc(p.sx, p.sy, d * 1.6 + 0.2, 0, Math.PI*2);
      ctx.fillStyle = 'rgba(255,255,255,' + Math.min(0.95, d * 0.9 + 0.05).toFixed(2) + ')';
      ctx.fill();
    });

    requestAnimationFrame(draw);
  }
  draw();

  /* ═══════════════════════════════════════════════
     SETTINGS — tab switching
  ═══════════════════════════════════════════════ */
  document.querySelectorAll('#hlSTabs .hl-s-tab').forEach(tab => {
    tab.addEventListener('click', () => {
      document.querySelectorAll('#hlSTabs .hl-s-tab').forEach(t => t.classList.remove('active'));
      document.querySelectorAll('.hl-s-panel').forEach(p => p.classList.remove('active'));
      tab.classList.add('active');
      const panel = document.getElementById('hlPanel-' + tab.dataset.panel);
      if (panel) panel.classList.add('active');
    });
  });

  /* ═══════════════════════════════════════════════
     TOGGLES — with ESP player model updates
  ═══════════════════════════════════════════════ */
  const espMap = {
    box2d:  'hlEspBox2d',
    box3d:  'hlEspBox3d',
    corner: 'hlEspCorner',
    skel:   'hlEspSkel'
  };

  document.querySelectorAll('.hl-toggle').forEach(toggle => {
    toggle.addEventListener('click', () => {
      toggle.classList.toggle('on');
      const esp = toggle.dataset.esp;
      if (esp && espMap[esp]) {
        const el = document.getElementById(espMap[esp]);
        if (el) el.style.display = toggle.classList.contains('on') ? '' : 'none';
      }
    });
  });

})();
</script>
