<style>
  /* ═══════════════════════════════════════════
     HIGHLIGHTS — BENTO GRID SECTION
  ═══════════════════════════════════════════ */
  .hl-section { background: #090909; padding: 0 0 100px; }
  .hl-section .container { max-width: 1100px; }

  .hl-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    grid-template-areas:
      "globe  payments payments"
      "settings settings notifs"
      "support support support";
    gap: 12px;
  }
  @media (max-width: 860px) {
    .hl-grid {
      grid-template-columns: 1fr;
      grid-template-areas: "globe" "payments" "settings" "notifs" "support";
    }
  }

  .hl-card {
    background: #0d0d10;
    border: 1px solid rgba(255,255,255,0.07);
    border-radius: 18px;
    overflow: hidden;
    position: relative;
    transition: border-color 0.3s ease;
  }
  .hl-card:hover { border-color: rgba(255,255,255,0.13); }

  .hl-globe-card    { grid-area: globe; }
  .hl-payments-card { grid-area: payments; display: flex; flex-direction: column; }
  .hl-settings-card { grid-area: settings; }
  .hl-notifs-card   { grid-area: notifs; }
  .hl-support-card  { grid-area: support; }

  .hl-label { padding: 16px 20px 20px; }
  .hl-label h3 { font-size: 0.95rem; font-weight: 700; color: #fff; margin: 0 0 5px; letter-spacing: -0.01em; }
  .hl-label p  { font-size: 0.79rem; color: rgba(255,255,255,0.38); line-height: 1.55; margin: 0; }

  /* ─── GLOBE ─── */
  .hl-globe-wrap {
    height: 220px; display: flex; align-items: center; justify-content: center;
    position: relative; cursor: grab; user-select: none;
  }
  .hl-globe-wrap:active { cursor: grabbing; }
  #hlGlobe { position: relative; z-index: 1; }
  .hl-globe-glow {
    position: absolute; inset: 0; pointer-events: none; z-index: 0;
    background: radial-gradient(circle at 50% 50%, rgba(80,100,255,0.13) 0%, transparent 60%);
  }

  /* ─── PAYMENTS ─── */
  .hl-pay-area {
    flex: 1; padding: 18px 0 6px; overflow: hidden;
    position: relative; display: flex; flex-direction: column;
    justify-content: center; gap: 10px;
  }
  .hl-pay-area::before, .hl-pay-area::after {
    content: ''; position: absolute; top: 0; bottom: 0; width: 70px; z-index: 2; pointer-events: none;
  }
  .hl-pay-area::before { left: 0;  background: linear-gradient(to right, #0d0d10, transparent); }
  .hl-pay-area::after  { right: 0; background: linear-gradient(to left,  #0d0d10, transparent); }

  .hl-pay-row { display: flex; gap: 10px; width: max-content; }
  .hl-pay-row-1 { animation: hl-lft 24s linear infinite; }
  .hl-pay-row-2 { animation: hl-rgt 30s linear infinite; }
  .hl-pay-row-1:hover, .hl-pay-row-2:hover { animation-play-state: paused; }
  @keyframes hl-lft { from { transform: translateX(0); }     to { transform: translateX(-50%); } }
  @keyframes hl-rgt { from { transform: translateX(-50%); }  to { transform: translateX(0); } }

  .hl-pay-icon {
    width: 52px; height: 52px; border-radius: 50%;
    background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.08);
    display: flex; align-items: center; justify-content: center; flex-shrink: 0;
    transition: background 0.2s, border-color 0.2s;
  }
  .hl-pay-icon:hover { background: rgba(255,255,255,0.1); border-color: rgba(255,255,255,0.2); }
  .hl-pay-icon svg { width: 24px; height: 24px; opacity: 0.6; }

  /* ─── SETTINGS ─── */
  .hl-settings-inner { display: flex; gap: 0; padding: 20px 20px 0; height: 100%; }
  .hl-settings-text { flex-shrink: 0; width: 148px; padding-right: 16px; }
  .hl-settings-text h3 { font-size: 1rem; font-weight: 700; color: #fff; margin: 0 0 6px; letter-spacing: -0.01em; }
  .hl-settings-text p  { font-size: 0.77rem; color: rgba(255,255,255,0.38); line-height: 1.55; margin: 0; }

  .hl-settings-frame {
    flex: 1; background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.07); border-bottom: none;
    border-radius: 12px 12px 0 0; overflow: hidden; display: flex; min-height: 210px;
  }

  .hl-s-sidebar { width: 118px; flex-shrink: 0; border-right: 1px solid rgba(255,255,255,0.06); padding: 8px 0; }
  .hl-s-tab {
    display: flex; align-items: center; gap: 6px; padding: 7px 10px;
    font-size: 0.7rem; font-weight: 500; color: rgba(255,255,255,0.35);
    cursor: pointer; transition: background 0.15s, color 0.15s; user-select: none;
  }
  .hl-s-tab:hover { background: rgba(255,255,255,0.04); color: rgba(255,255,255,0.6); }
  .hl-s-tab.active { background: rgba(99,102,241,0.12); color: #818cf8; font-weight: 600; }
  .hl-s-tab svg { width: 12px; height: 12px; flex-shrink: 0; opacity: 0.7; }
  .hl-s-tab.active svg { opacity: 1; }

  .hl-s-main { flex: 1; padding: 10px 12px; overflow: hidden; }
  .hl-s-panel { display: none; animation: hl-fi 0.18s ease; height: 100%; }
  .hl-s-panel.active { display: flex; flex-direction: column; }
  @keyframes hl-fi { from { opacity: 0; transform: translateY(3px); } to { opacity: 1; transform: none; } }

  .hl-s-panel-head { font-size: 0.76rem; font-weight: 700; color: rgba(255,255,255,0.75); margin-bottom: 2px; }
  .hl-s-panel-sub  { font-size: 0.63rem; color: rgba(255,255,255,0.28); margin-bottom: 6px; }
  .hl-s-divider    { height: 1px; background: rgba(255,255,255,0.06); margin-bottom: 6px; }

  /* Controls + player model side by side */
  .hl-s-body { display: flex; gap: 8px; flex: 1; min-height: 0; }
  .hl-s-controls { flex: 1; }

  .hl-s-cols { display: grid; grid-template-columns: 1fr 1fr; gap: 0 8px; }
  .hl-s-group-lbl {
    font-size: 0.58rem; font-weight: 700; color: rgba(255,255,255,0.25);
    letter-spacing: 0.07em; text-transform: uppercase; margin-bottom: 5px;
  }
  .hl-s-row { display: flex; align-items: center; justify-content: space-between; margin-bottom: 5px; }
  .hl-s-row-lbl { font-size: 0.63rem; color: rgba(255,255,255,0.4); }

  /* Toggle */
  .hl-toggle {
    width: 26px; height: 14px; border-radius: 999px;
    background: rgba(255,255,255,0.1); position: relative;
    cursor: pointer; flex-shrink: 0; transition: background 0.2s;
  }
  .hl-toggle::after {
    content: ''; position: absolute; width: 10px; height: 10px;
    border-radius: 50%; background: rgba(255,255,255,0.35); top: 2px; left: 2px;
    transition: left 0.2s, background 0.2s;
  }
  .hl-toggle.on { background: #6366f1; }
  .hl-toggle.on::after { left: 14px; background: #fff; }

  /* Player model preview */
  .hl-player-preview {
    width: 90px; flex-shrink: 0;
    background: rgba(0,0,0,0.25); border: 1px solid rgba(255,255,255,0.06);
    border-radius: 8px; display: flex; align-items: center; justify-content: center;
    position: relative; overflow: hidden;
  }
  .hl-player-preview::before {
    content: ''; position: absolute; bottom: 0; left: 0; right: 0; height: 20px;
    background: linear-gradient(to top, rgba(0,0,0,0.4), transparent);
  }
  .hl-player-preview svg { width: 100%; height: 100%; }

  /* Non-visuals panel layout */
  .hl-s-generic { flex: 1; }

  /* ─── NOTIFICATIONS ─── */
  .hl-notifs-top { padding: 14px 14px 0; display: flex; flex-direction: column; gap: 8px; }

  @keyframes hl-notif-float {
    0%, 100% { transform: translateY(0px); box-shadow: 0 2px 8px rgba(0,0,0,0.1); }
    50%       { transform: translateY(-6px); box-shadow: 0 10px 22px rgba(0,0,0,0.35); }
  }
  .hl-notifs-top .hl-notif:nth-child(1) { animation: hl-notif-float 3.2s ease-in-out infinite; }
  .hl-notifs-top .hl-notif:nth-child(2) { animation: hl-notif-float 3.2s ease-in-out infinite 1.07s; }
  .hl-notifs-top .hl-notif:nth-child(3) { animation: hl-notif-float 3.2s ease-in-out infinite 2.14s; }

  .hl-notif {
    display: flex; align-items: flex-start; gap: 9px;
    background: rgba(255,255,255,0.035); border: 1px solid rgba(255,255,255,0.07);
    border-radius: 11px; padding: 10px 11px;
    transition: background 0.2s, border-color 0.2s; cursor: default;
  }
  .hl-notif:hover { background: rgba(255,255,255,0.06); border-color: rgba(255,255,255,0.13); }
  .hl-notif.faded { opacity: 0.35; animation: none !important; pointer-events: none; }

  .hl-notif-av {
    width: 28px; height: 28px; border-radius: 8px;
    background: rgba(99,102,241,0.15); border: 1px solid rgba(99,102,241,0.25);
    display: flex; align-items: center; justify-content: center; flex-shrink: 0;
  }
  .hl-notif-av.green { background: rgba(34,197,94,0.12); border-color: rgba(34,197,94,0.25); }
  .hl-notif-av svg { width: 12px; height: 12px; color: #818cf8; }
  .hl-notif-av.green svg { color: #22c55e; }

  .hl-notif-body { flex: 1; min-width: 0; }
  .hl-notif-row { display: flex; align-items: center; justify-content: space-between; gap: 6px; margin-bottom: 2px; }
  .hl-notif-title { font-size: 0.74rem; font-weight: 700; color: rgba(255,255,255,0.85); }
  .hl-notif-time  { font-size: 0.62rem; color: rgba(255,255,255,0.25); white-space: nowrap; flex-shrink: 0; }
  .hl-notif-desc  { font-size: 0.67rem; color: rgba(255,255,255,0.35); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }

  /* ─── SUPPORT ─── */
  .hl-support-card {
    display: flex; flex-direction: column; align-items: center;
    justify-content: center; padding: 52px 24px; text-align: center;
  }
  .hl-sup-num {
    font-size: clamp(3.5rem, 9vw, 5.5rem); font-weight: 900;
    line-height: 0.9; letter-spacing: -0.05em;
    background: linear-gradient(135deg, #c4b5fd 0%, #a78bfa 40%, #6366f1 100%);
    -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
  }
  .hl-sup-word { font-size: clamp(1.6rem, 4vw, 2.5rem); font-weight: 900; letter-spacing: 0.14em; color: #fff; margin-bottom: 30px; }
  .hl-sup-btns { display: flex; align-items: center; gap: 10px; flex-wrap: wrap; justify-content: center; }

  .hl-btn {
    display: inline-flex; align-items: center; gap: 7px; font-weight: 700;
    font-size: 0.84rem; padding: 11px 22px; border-radius: 10px;
    text-decoration: none; transition: all 0.2s ease;
    letter-spacing: 0.01em; white-space: nowrap; cursor: pointer; border: none;
  }
  .hl-btn svg { width: 14px; height: 14px; flex-shrink: 0; }
  .hl-btn-primary { background: #6366f1; color: #fff; border: 1px solid transparent; }
  .hl-btn-primary:hover { background: #4f46e5; color: #fff; transform: translateY(-2px); box-shadow: 0 6px 20px rgba(99,102,241,0.35); }
  .hl-btn-secondary { background: rgba(255,255,255,0.05); color: rgba(255,255,255,0.7); border: 1px solid rgba(255,255,255,0.1); }
  .hl-btn-secondary:hover { background: rgba(255,255,255,0.09); border-color: rgba(255,255,255,0.2); color: #fff; transform: translateY(-2px); }
</style>

